{
    "name": "smrt-systems/couch-odm",
    "description": "A simple object data mapper for CouchDB.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SmrtSystems\\Couch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmrtSystems\\Couch\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Christoffer Palm",
            "email": "christoffer.p@smrtsystems.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "psr/cache": "^3.0",
        "symfony/cache": "^6.0|^7.0|^8.0",
        "symfony/http-client": "^6.0|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "symfony/var-dumper": "^6.0|^7.0|^8.0"
    },
    "suggest": {
        "predis/predis": "Required for Redis caching layer",
        "ext-redis": "Alternative to predis for Redis caching"
    },
    "config": {
        "sort-packages": true
    }
}
